#!/bin/sh
# Pre-commit hook: run gitleaks, prettier, eslint, and fast security tests
# Install: git config core.hooksPath .githooks

echo "--- pre-commit: gitleaks ---"
GITLEAKS="$(dirname "$0")/bin/gitleaks"
if [ -x "$GITLEAKS" ]; then
  "$GITLEAKS" detect --no-git --verbose 2>/dev/null
elif command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --no-git --verbose 2>/dev/null
else
  echo "WARNING: gitleaks not found; skipping secret scan"
  echo "Install: https://github.com/gitleaks/gitleaks/releases"
fi
if [ $? -ne 0 ]; then
  echo "FAILED: gitleaks detected secrets. Remove them and try again."
  exit 1
fi

echo "--- pre-commit: prettier ---"
npx prettier --check .
if [ $? -ne 0 ]; then
  echo "FAILED: prettier check failed. Run 'npm run format' to fix."
  exit 1
fi

echo "--- pre-commit: eslint ---"
npx eslint .
if [ $? -ne 0 ]; then
  echo "FAILED: eslint found issues. Fix them before committing."
  exit 1
fi

echo "--- pre-commit: fast security tests ---"
npx tsx --test test/security/path-escape.test.ts test/security/sql-injection.test.ts
if [ $? -ne 0 ]; then
  echo "FAILED: security tests did not pass."
  exit 1
fi

echo "--- pre-commit: passed ---"
